<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:id="@+id/toolbar"
    android:background="@color/nav_bg"
    android:gravity="center_vertical">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:id="@+id/menu"
        android:src="@drawable/baseline_menu_24"
        android:padding="4dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="EcoSmart"
        android:textColor="@color/nav_text"
        android:paddingStart="10dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"/>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/toolbar_bell"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/outline_circle_notifications_24"
            android:padding="4dp"/>

        <View
            android:id="@+id/notification_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_notification_dot"
            android:layout_alignTop="@id/toolbar_bell"
            android:layout_alignEnd="@id/toolbar_bell"
            android:visibility="gone"/>

    </RelativeLayout>

    <ImageView
        android:id="@+id/toolbar_profile_photo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/outline_contacts_product_24"
        android:background="@drawable/bg_circle"
        android:scaleType="centerCrop"
        android:padding="2dp"/>

</LinearLayout>